# Direct API URL (works with Vite dev, preview, and build — backend CORS must allow your origin)
VITE_API_BASE_URL=http://localhost:8000/api/waste

# Optional: only used if you prefer proxying via /api in vite.config.js dev server
# VITE_API_BASE_URL=/api/waste
# VITE_API_PROXY_TARGET=http://localhost:8000
